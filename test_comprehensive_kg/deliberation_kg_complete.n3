@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix del: <https://w3id.org/deliberation/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/deliberation/ontology> a owl:Ontology ;
    rdfs:label "Deliberation Ontology"@en ;
    dcterms:created "2025-03-03"^^xsd:date ;
    dcterms:creator "Simone Vagnoni" ;
    dcterms:description "An ontology for representing and analyzing deliberative processes, arguments, and discourse."@en ;
    dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2025-03-20"^^xsd:date ;
    dcterms:title "Deliberation Ontology"@en ;
    vann:preferredNamespacePrefix "deliberation" ;
    vann:preferredNamespaceUri "https://w3id.org/deliberation/ontology#" ;
    rdfs:comment "A comprehensive model for representing deliberative processes across different platforms and contexts."@en ;
    owl:imports <https://w3id.org/deliberation/mappings> ;
    owl:versionInfo "1.0.0" .

del:Consensus a owl:Class ;
    rdfs:label "Consensus" ;
    rdfs:comment "Agreement reached through deliberation." .

del:LegalSource a owl:Class ;
    rdfs:label "Legal Source" ;
    rdfs:comment "Legal documents, frameworks, or interpretations relevant to deliberations." ;
    rdfs:subClassOf del:InformationResource .

del:attacks a owl:ObjectProperty ;
    rdfs:label "attacks" ;
    rdfs:comment "Indicates that an argument attacks another argument or position." ;
    rdfs:domain del:Argument ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( del:Argument del:Position ) ] .

del:containsFallacy a owl:ObjectProperty ;
    rdfs:label "contains fallacy" ;
    rdfs:comment "Indicates that an argument contains a specific type of logical fallacy." ;
    rdfs:domain del:Argument ;
    rdfs:range del:FallacyType .

del:endDate a owl:DatatypeProperty ;
    rdfs:label "end date" ;
    rdfs:comment "The end date and time of a deliberation process or stage." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( del:DeliberationProcess del:Stage ) ] ;
    rdfs:range xsd:dateTime .

del:hasArgument a owl:ObjectProperty ;
    rdfs:label "has argument" ;
    rdfs:comment "Relates a deliberation process to arguments made within it." ;
    rdfs:domain del:DeliberationProcess ;
    rdfs:range del:Argument .

del:hasConclusion a owl:ObjectProperty ;
    rdfs:label "has conclusion" ;
    rdfs:comment "Relates an argument to its conclusion." ;
    rdfs:domain del:Argument ;
    rdfs:range del:Conclusion .

del:hasContribution a owl:ObjectProperty ;
    rdfs:label "has contribution" ;
    rdfs:comment "Relates a deliberation process to contributions made within it." ;
    rdfs:domain del:DeliberationProcess ;
    rdfs:range del:Contribution .

del:hasEvidence a owl:ObjectProperty ;
    rdfs:label "has evidence" ;
    rdfs:comment "Relates an argument or premise to supporting evidence." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( del:Argument del:Premise ) ] ;
    rdfs:range del:Evidence .

del:hasParticipant a owl:ObjectProperty ;
    rdfs:label "has participant" ;
    rdfs:comment "Relates a deliberation process to its participants." ;
    rdfs:domain del:DeliberationProcess ;
    rdfs:range del:Participant .

del:hasPremise a owl:ObjectProperty ;
    rdfs:label "has premise" ;
    rdfs:comment "Relates an argument to its premises." ;
    rdfs:domain del:Argument ;
    rdfs:range del:Premise .

del:hasRole a owl:ObjectProperty ;
    rdfs:label "has role" ;
    rdfs:comment "Relates a participant to their role in a deliberation." ;
    rdfs:domain del:Participant ;
    rdfs:range del:Role .

del:hasStage a owl:ObjectProperty ;
    rdfs:label "has stage" ;
    rdfs:comment "Relates a deliberation process to its stages." ;
    rdfs:domain del:DeliberationProcess ;
    rdfs:range del:Stage .

del:hasTopic a owl:ObjectProperty ;
    rdfs:label "has topic" ;
    rdfs:comment "Relates a deliberation process to its topic." ;
    rdfs:domain del:DeliberationProcess ;
    rdfs:range del:Topic .

del:isAffiliatedWith a owl:ObjectProperty ;
    rdfs:label "is affiliated with" ;
    rdfs:comment "Relates a participant to organizations they are affiliated with." ;
    rdfs:domain del:Participant ;
    rdfs:range del:Organization .

del:madeBy a owl:ObjectProperty ;
    rdfs:label "made by" ;
    rdfs:comment "Relates a contribution to the participant who made it." ;
    rdfs:domain del:Contribution ;
    rdfs:range del:Participant .

del:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "The name of an entity." ;
    rdfs:range xsd:string .

del:platformIdentifier a owl:DatatypeProperty ;
    rdfs:label "platform identifier" ;
    rdfs:comment "An identifier specific to a particular platform." ;
    rdfs:domain del:CrossPlatformIdentifier ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf del:identifier .

del:references a owl:ObjectProperty ;
    rdfs:label "references" ;
    rdfs:comment "Relates a contribution or argument to information resources it references." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( del:Argument del:Contribution ) ] ;
    rdfs:range del:InformationResource .

del:responseTo a owl:ObjectProperty ;
    rdfs:label "response to" ;
    rdfs:comment "Relates a contribution to another contribution it responds to." ;
    rdfs:domain del:Contribution ;
    rdfs:range del:Contribution .

del:startDate a owl:DatatypeProperty ;
    rdfs:label "start date" ;
    rdfs:comment "The start date and time of a deliberation process or stage." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( del:DeliberationProcess del:Stage ) ] ;
    rdfs:range xsd:dateTime .

del:supports a owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:comment "Indicates that an argument supports another argument or position." ;
    rdfs:domain del:Argument ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( del:Argument del:Position ) ] .

del:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:comment "The textual content of a contribution, argument, position, premise, or conclusion." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( del:Argument del:Contribution del:Position del:Premise del:Conclusion ) ] ;
    rdfs:range xsd:string .

del:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp" ;
    rdfs:comment "The date and time when a contribution was made." ;
    rdfs:domain del:Contribution ;
    rdfs:range xsd:dateTime .

del:url a owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:comment "The URL of an information resource." ;
    rdfs:domain del:InformationResource ;
    rdfs:range xsd:anyURI .

<https://w3id.org/deliberation/resource/decide_madrid_process> a del:DeliberationProcess ;
    del:hasContribution <https://w3id.org/deliberation/resource/madrid_proposal_19>,
        <https://w3id.org/deliberation/resource/madrid_proposal_7> ;
    del:hasTopic <https://w3id.org/deliberation/resource/madrid_topic_19>,
        <https://w3id.org/deliberation/resource/madrid_topic_7> ;
    del:identifier "decide_madrid_process" ;
    del:name "Decide Madrid Participatory Democracy Platform" .

<https://w3id.org/deliberation/resource/delidata_process> a del:DeliberationProcess ;
    del:identifier "delidata_process" ;
    del:name "DeliData Conversations" ;
    del:platform "DeliData" .

