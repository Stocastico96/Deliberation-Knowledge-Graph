  {
    "@id": "https://w3id.org/deliberation/resource/contribution_36",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
    ],
    "https://w3id.org/deliberation/ontology#identifier": [
      {
        "@value": "contribution_36"
