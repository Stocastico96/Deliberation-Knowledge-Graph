    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "Man muss nun wirklich kein Freund des Assad-Regimes sein, um zu erkennen, dass das wirklich groteske Fake News waren, und ich finde, es muss ein deutliches Signal von diesem Parlament ausgehen, dass wir so etwas nicht dulden hier in diesen heiligen Hallen."
      }
    ],
