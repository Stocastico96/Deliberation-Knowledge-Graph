      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "The corrigenda are available on the plenary webpage. Their titles will be published in the minutes of this sitting."
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
