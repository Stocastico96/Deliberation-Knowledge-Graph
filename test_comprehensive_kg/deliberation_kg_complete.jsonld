      {
        "@value": "Juan Carlos Girauta Vidal"
      }
    ]
  },
  {
    "@id": "https://w3id.org/deliberation/ontology#LegalSource",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
