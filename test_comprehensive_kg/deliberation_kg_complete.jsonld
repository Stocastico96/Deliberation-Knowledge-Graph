    ],
    "https://w3id.org/deliberation/ontology#madeBy": [
      {
        "@id": "https://w3id.org/deliberation/resource/participant_82"
      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "Ik roep de Commissie dan ook op om de komende tijd meer ambitie te tonen. Dit is een heel goed voorstel, maar het gaat nog niet ver genoeg. U bevindt zich op een betere weg. Zoals we in Nederland zeggen: \"Beter ten halve gekeerd dan ten hele gedwaald\". Ik wens u daarbij heel veel succes."
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-10T19:51:32"
      }
    ]
  },
  {
    "@id": "https://w3id.org/deliberation/resource/contribution_81",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
