    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "Pasti mora skrajno nedemokratiÄni cordon sanitaire. In nedopustna je zloraba pravosodja, da se nekomu onemogoÄi kandidaturo na volitvah. Potrebujemo popolno svobodo govora in spoÅ¡tovanje volilnih odloÄitev ljudstva.\nPotrebujemo vrnitev k pravim vrednotam. To so krÅ¡Äanske vrednote. Bog vas Å¾ivi, Bog Å¾ivi Evropo. Bog Å¾ivi mojo domovino, Slovenijo."
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
