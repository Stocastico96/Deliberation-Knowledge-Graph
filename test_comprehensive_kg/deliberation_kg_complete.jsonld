      {
        "@value": "Jonas SjÃ¶stedt,"
      }
    ]
  },
  {
    "@id": "https://w3id.org/deliberation/resource/contribution_73",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
