  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_184">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_184</del:identifier>
    <del:text>ChciaГ…ВӮbym oГ…ВӣwiadczyГ„ВҮ pani Virkkunen i Komisji Europejskiej, Г…Вјe Polacy nie Г…ВјyczГ„В… sobie ingerencji w polskie wybory. Organizacja czegokolwiek ponad gГ…ВӮowami PolakГғВіw w sprawie wyborГғВіw bГ„Вҷdzie potraktowana jako atak na polskГ„В… demokracjГ„Вҷ. Nie Г…Вјyczymy sobie ingerencji w nasze sprawy. Komisja Europejska powinna w myГ…Вӣl traktatГғВіw trzymaГ„ВҮ rГ„Вҷce z dala od wyborГғВіw w Polsce.</del:text>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T21:45:11</del:timestamp>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T14:31:14</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_135"/>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_134"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_183"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_184"/>
