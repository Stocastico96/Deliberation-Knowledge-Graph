  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_238">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_238</del:identifier>
    <del:text>ГғВҺn acest context, doresc sГ„Вғ subliniez necesitatea implementГ„Вғrii unui plan ambiГҲВӣios de investiГҲВӣii, ГғВ®n special ГғВ®n perspectiva noului Buget UE 2028-2034, care sГ„Вғ combine fonduri europene cu reglementГ„Вғri flexibile privind ajutoarele de stat, pentru a consolida ГҲВҷi extinde capacitГ„ВғГҲВӣile de producГҲВӣie farmaceuticГ„Вғ pe teritoriul Uniunii Europene. State precum RomГғВўnia, care beneficiazГ„Вғ deja de infrastructurГ„Вғ industrialГ„Вғ farmaceuticГ„Вғ, centre universitare de excelenГҲВӣГ„Вғ ГҲВҷi un capital uman specializat, trebuie sГ„Вғ devinГ„Вғ piloni esenГҲВӣiali ГғВ®n asigurarea securitГ„ВғГҲВӣii farmaceutice a Europei.</del:text>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_174"/>
  </rdf:Description>
