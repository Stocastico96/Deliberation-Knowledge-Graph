  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_287">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_287</del:identifier>
    <del:name>Luis-VicenГҲВӣiu Lazarus</del:name>
    <del:platform>EU Parliament</del:platform>
