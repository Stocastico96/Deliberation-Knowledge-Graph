  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_251">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_251</del:identifier>
    <del:name>Tobias Cremer</del:name>
