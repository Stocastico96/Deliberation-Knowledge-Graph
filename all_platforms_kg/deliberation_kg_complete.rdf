  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_136">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_136</del:identifier>
    <del:name>Cynthia NГғВӯ MhurchГғВә</del:name>
    <del:name>Nina Carberry</del:name>
    <del:platform>EU Parliament</del:platform>
