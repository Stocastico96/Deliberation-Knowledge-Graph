  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_375">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_375</del:identifier>
    <del:name>Catarina Vieira</del:name>
    <del:platform>EU Parliament</del:platform>
