  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_205">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_205</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T15:00:28</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_150"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_204"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_205"/>
