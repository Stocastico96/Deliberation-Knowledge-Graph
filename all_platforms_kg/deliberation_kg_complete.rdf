  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_513">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_513</del:identifier>
    <del:text>BDP u Siriji i dalje je manje od polovice vrijednosti iz 2011. godine. Infrastruktura naravno da je znaГ„ВҚajno oГ…ВЎteГ„ВҮena, a veГ„ВҮina Sirijaca Г…Вҫivi i dalje u siromaГ…ВЎtvu. TroГ…ВЎkovi ponovne izgradnje zemlje mogli bi se kretati pa do 200 milijardi eura.
Europska unija i njezine drГ…Вҫave Г„ВҚlanice su mobilizirale veГ„ВҮ sada viГ…ВЎe od 35 milijardi, ali, naravno, pitanje je sada koji Г„ВҮe biti prioriteti naГ…ВЎeg djelovanja. To naravno da jesu mir, sigurnost, jedinstvo zemlje, zaГ…ВЎtita svih manjina, ali posebno je zabrinjavajuГ„ВҮa situacija krГ…ВЎГ„ВҮana. Do 2011. u Siriji je Г…Вҫivjelo oko milijun krГ…ВЎГ„ВҮana, a danas ih je oko 300 tisuГ„ВҮa i oni svaki dan strepe za vlastitu sigurnost.
Dakle, sve su manjine vaГ…Вҫne, ali ako se Europa ne zauzme za krГ…ВЎГ„ВҮane, onda to nitko neГ„ВҮe. Stoga, ne smijemo ih zaboraviti.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T22:18:34</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_289"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_512"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_513"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_101">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_101</del:identifier>
    <del:name>Julien Sanchez</del:name>
    <del:name>Raquel GarcГғВӯa Hermida-Van Der Walle</del:name>
    <del:platform>EU Parliament</del:platform>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_PfE"/>
