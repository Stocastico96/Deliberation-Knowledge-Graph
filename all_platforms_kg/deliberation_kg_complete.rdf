  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_274">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_274</del:identifier>
    <del:text>PalautusjГғВӨrjestelmГғВӨ on yksi iso vitsi. Euroopassa ylpeillГғВӨГғВӨn oikeusvaltioperiaatteesta ja sen kunnioittamisesta. HyvГғВӨ niin, mutta mikГғВӨ periaate se sellainen on, joka ei mahdollista laittomasti maassa olevien palauttamista.
Palautusten tehostaminen on myГғВ¶s turvallisuuskysymys. Erityisesti LГғВӨhi-idГғВӨn ja Afrikan maista tulleet muuttajat ovat selvГғВӨsti yliedustettuina rikostilastoissa. Milloin Eurooppa oikein herГғВӨГғВӨ? Kielteisen pГғВӨГғВӨtГғВ¶ksen saaneet ja vakaviin rikoksiin syyllistyneet on palautettava viipymГғВӨttГғВӨ. Kehitysapu on tehtГғВӨvГғВӨ ehdolliseksi sille, ettГғВӨ maat suostuvat ottamaan vastaan omia kansalaisiaan. Palautuskeskuksia on sijoitettava EU-maiden ulkopuolelle.
HyvГғВӨt kollegat, tehdГғВӨГғВӨn tГғВӨstГғВӨ palautusten vuosi.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T16:47:56</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_132"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_273"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_274"/>
  </rdf:Description>
