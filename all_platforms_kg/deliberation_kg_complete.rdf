  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_21">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_21</del:identifier>
    <del:name>Younous Omarjee,</del:name>
    <del:name>MГ„ВҒrtiГ…ВҶГ…ВЎ StaГ„В·is</del:name>
