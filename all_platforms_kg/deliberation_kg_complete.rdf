  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_428">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_428</del:identifier>
    <del:text>A tiszta ipar stratГғВ©gia sem hoz vГғВЎltozГғВЎst. Ez egy ГғВЎtcГғВӯmkГғВ©zett zГғВ¶ld paktum. A BizottsГғВЎg szeretnГғВ©, ha a tiszta technolГғВіgiai termГғВ©kek ГғВ¶sszetevГ…В‘inek 40 szГғВЎzalГғВ©kГғВЎt az EU-ban gyГғВЎrtanГғВЎk. Ma a napelemeket ГғВ©s szГғВ©lkerekeket szinte kizГғВЎrГғВіlag KГғВӯnГғВЎban ГғВЎllГғВӯtjГғВЎk elГ…В‘. ГғВҚgy kГғВ©rdezem, hogy ez mennyire reГғВЎlis? KГғВ©szГғВјlt-e ehhez megvalГғВіsГғВӯthatГғВіsГғВЎgi elemzГғВ©s? Olyan intГғВ©zkedГғВ©sek kellenek, melyek mГғВЎr rГғВ¶vidtГғВЎvon segГғВӯtsГғВ©get nyГғВәjtanak az iparnak ГғВ©s az embereknek. Ilyen volna pГғВ©ldГғВЎul az energiaГғВЎrak azonnali csГғВ¶kkentГғВ©se. BrГғВјsszel ehelyett folytatja hadjГғВЎratГғВЎt a rezsicsГғВ¶kkentГғВ©s ellen, ГғВ©s ki akarja vezetni a fosszilisenergia-projektek tГғВЎmogatГғВЎsГғВЎt. A patriГғВіtГғВЎk ehhez nem fognak asszisztГғВЎlni. Nem kГғВ©rГғВјnk az ideolГғВіgia alapГғВә gazdasГғВЎgpolitikГғВЎbГғВіl.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T20:19:19</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_305"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_427"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_428"/>
  </rdf:Description>
