  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_354">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_354</del:identifier>
    <del:name>Alexander Sell,</del:name>
