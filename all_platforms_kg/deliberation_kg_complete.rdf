  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_326">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_326</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T18:11:51</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_81"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_325"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_326"/>
