  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_425">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_425</del:identifier>
    <del:text>PГғВӯГ…ВЎete, Г…Вҫe dekarbonizГғВЎcia sa stГғВЎva nielen environmentГғВЎlnym cieГ„Вҫom, ale aj naГ…ВЎou rastovou stratГғВ©giou. AkГғВЎ rastovГғВЎ stratГғВ©gia? VГ…ВЎak kvГғВҙli dekarbonizГғВЎcii mГғВЎme v EurГғВіpe najdrahГ…ВЎie ceny energiГғВӯ na svete. PriemyselnГғВӯ vГғВҪrobcovia by mali obmedzovaГ…ВҘ vГғВҪrobu podГ„Вҫa toho, koГ„Вҫko bude stГғВЎГ…ВҘ elektrina. Tak Г„Вҫudia budГғВә doma Г„ВҚakaГ…ВҘ na to, kedy zaГ„ВҚne svietiГ…ВҘ slnko a zaГ„ВҚnГғВә fungovaГ…ВҘ solГғВЎrne panely, aby bola elektrina lacnejГ…ВЎia. Toto nie je plГғВЎn na hospodГғВЎrsky rast, toto je plГғВЎn na katastrofu a zastavte to. Zastavte tГғВәto nezmyselnГғВә zelenГғВә politiku.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T20:14:36</del:timestamp>
