  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/creitem16">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Topic"/>
    <del:identifier>creitem16</del:identifier>
    <del:name>Cutting red tape and simplifying business in the EU: the first Omnibus proposals (debate)</del:name>
    <del:name>Approval of the minutes of the previous sitting</del:name>
    <skos:broader rdf:resource="https://w3id.org/deliberation/resource/creitem4"/>
    <skos:broader rdf:resource="https://w3id.org/deliberation/resource/creitem21"/>
    <skos:broader rdf:resource="https://w3id.org/deliberation/resource/creitem27"/>
