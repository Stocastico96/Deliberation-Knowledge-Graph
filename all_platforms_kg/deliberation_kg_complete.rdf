  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_298">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_298</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T17:20:30</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_77"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_297"/>
