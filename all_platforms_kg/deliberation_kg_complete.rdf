  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_325">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_325</del:identifier>
    <del:text>Sie fГғВ¶rdernГӮВ ГўВҖВ“ das muss man sich mal vergegenwГғВӨrtigenГӮВ ГўВҖВ“ Sie fГғВ¶rdern und hegen und pflegen mehr die RГғВјstungsindustrie als das, was Sie im Moment in der EU fГғВјr die Kinder, fГғВјr ihre Zukunft investieren und tun, und das ist inakzeptabel. AufrГғВјstung wird weder Europa noch die Welt sicherer machen. Sie behaupten, damit wГғВјrden Sie sogar die Demokratie stГғВӨrken. Im Gegenteil: Militarismus schwГғВӨcht die liberale Demokratie. Deshalb sagen wir Nein!
(Die Rednerin ist damit einverstanden, auf eine Frage nach dem Verfahren der ГўВҖВһblauen KarteГўВҖВң zu antworten.)</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T18:10:22</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_80"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_324"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_325"/>
  </rdf:Description>
