  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_457">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_457</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T20:57:09</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_326"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_456"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_457"/>
