  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_484">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_484</del:identifier>
    <del:text>Schriftliche ErklГғВӨrungen (Artikel 178)</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T21:38:11</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_14"/>
