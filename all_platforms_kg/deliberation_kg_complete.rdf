  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_276">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_276</del:identifier>
    <del:text>Az eurГғВіpai polgГғВЎrok viszont a tГғВ¶meges illegГғВЎlis bevГғВЎndorlГғВЎs azonnali megГғВЎllГғВӯtГғВЎsГғВЎt, a hatГғВЎrok vГғВ©delmГғВ©t akarjГғВЎk. Az emberek vissza akarjГғВЎk kapni a biztonsГғВЎgos eurГғВіpai ГғВ©letГғВјket. Itt az ideje, hogy BrГғВјsszellel szemben visszaszerezzГғВјk az ellenГ…В‘rzГғВ©st hatГғВЎraink felett. Az illegГғВЎlis migrГғВЎnsokat tilos beengedni EurГғВіpГғВЎba. Az a megfelelГ…В‘ visszatГғВ©rГғВӯtГғВ©si, visszatoloncolГғВЎsi gyakorlat, hogy az illegГғВЎlis migrГғВЎnsok belГғВ©pГғВ©sГғВ©t az UniГғВі kГғВјlsГ…В‘ hatГғВЎrainГғВЎl megakadГғВЎlyozzuk, ГғВ©s azonnal, kГғВ©slekedГғВ©s, kifogГғВЎs nГғВ©lkГғВјl visszafordГғВӯtjuk Г…В‘ket.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T16:50:56</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_17"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_275"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_276"/>
  </rdf:Description>
