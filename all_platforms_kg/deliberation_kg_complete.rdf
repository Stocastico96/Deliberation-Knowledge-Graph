  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_246">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_246</del:identifier>
    <del:name>Petras AuГ…ВЎtreviГ„ВҚius</del:name>
    <del:platform>EU Parliament</del:platform>
