    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Topic"/>
    <del:identifier>creitem11</del:identifier>
    <del:name>Supporting the EUГўВҖВҷs most vulnerable regions against devastating effects of climate change, such as the recent cyclone hitting La RГғВ©union (debate)</del:name>
    <del:name>Appointment of the Vice-Chair of the Single Resolution Board (A10-0026/2025 - Aurore Lalucq) (vote)</del:name>
    <skos:related rdf:resource="https://w3id.org/deliberation/resource/creitem9"/>
