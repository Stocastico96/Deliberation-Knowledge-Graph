  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_303">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_303</del:identifier>
    <del:text>Written Statements (Rule 178)</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T17:27:24</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_1"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_302"/>
