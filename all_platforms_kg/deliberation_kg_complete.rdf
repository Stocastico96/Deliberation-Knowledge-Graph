    <del:identifier>creitem27</del:identifier>
    <del:name>Approval of the minutes of the sitting</del:name>
    <skos:narrower rdf:resource="https://w3id.org/deliberation/resource/creitem4"/>
    <skos:narrower rdf:resource="https://w3id.org/deliberation/resource/creitem16"/>
