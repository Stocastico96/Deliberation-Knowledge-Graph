  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_337">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_337</del:identifier>
    <del:name>JonГғВЎs FernГғВЎndez</del:name>
