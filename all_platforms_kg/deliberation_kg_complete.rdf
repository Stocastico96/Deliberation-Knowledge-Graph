    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_122"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_169"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_170"/>
  </rdf:Description>
