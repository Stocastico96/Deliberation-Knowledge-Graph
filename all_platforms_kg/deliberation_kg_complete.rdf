  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/creitem18">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Topic"/>
    <del:identifier>creitem18</del:identifier>
    <del:name>European Social Fund Plus post-2027 (short presentation)</del:name>
    <del:name>Presentation of the proposal on Critical Medicines Act (CMA) (debate)</del:name>
    <skos:related rdf:resource="https://w3id.org/deliberation/resource/creitem13"/>
