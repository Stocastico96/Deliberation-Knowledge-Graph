    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_242</del:identifier>
    <del:name>ГҺВ“ГҺВ№ГҸВҺГҸВҒГҺВіГҺВҝГҸВӮ ГҺВ“ГҺВөГҸВүГҸВҒГҺВіГҺВҜГҺВҝГҸ</del:name>
    <del:platform>EU Parliament</del:platform>
