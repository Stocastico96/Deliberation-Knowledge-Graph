  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_117">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_117</del:identifier>
    <del:text>La votazione si svolgerГғВ  domani.</del:text>
    <del:text>We vote on the appointment of Radek Urban.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T19:58:53</del:timestamp>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T12:56:19</del:timestamp>
