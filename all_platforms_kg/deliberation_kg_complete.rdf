  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_109">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_109</del:identifier>
    <del:name>Claudiu-Richard TГғВўrziu</del:name>
    <del:name>Judita LaГ…ВЎГ…ВЎГғВЎkovГғВЎ</del:name>
    <del:platform>EU Parliament</del:platform>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_ECR"/>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_NI"/>
