  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_466">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_466</del:identifier>
    <del:text>Mit dem Vorschlag fГғВјr LeitmГғВӨrkte fГғВјr dekarbonisierte Produkte wie zum Beispiel Stahl macht die Kommission einen wichtigen Schritt nach vorne, denn damit werden nicht nur stГғВӨrkere nationale Beihilfen mГғВ¶glich, sondern auch ГғВ¶ffentliche Beschaffungen an andere Kriterien gebunden. Aber wird denn das kritische Merkmal die lokale Produktion sein oder dekarbonisierte europГғВӨische Produktion? Deswegen, um das zu klГғВӨren, brauchen wir jetzt sehr, sehr schnell das Beschleunigungsgesetz fГғВјr die Endkarbonisierung der Industrie, so schnell wie mГғВ¶glich.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T21:09:32</del:timestamp>
