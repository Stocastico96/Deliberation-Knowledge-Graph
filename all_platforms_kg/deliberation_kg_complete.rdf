  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_131">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_131</del:identifier>
    <del:name>ГҗВ ГҗВ°ГҗВҙГҗВ° ГҗВӣГҗВ°ГҗВ№ГҗВәГҗВҫГҗВІГҗВ°</del:name>
    <del:name>Nikolina Brnjac</del:name>
    <del:platform>EU Parliament</del:platform>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_ESN"/>
