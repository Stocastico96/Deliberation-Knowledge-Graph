  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_401">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_401</del:identifier>
    <del:text>Poate nu ar mai trebui nici noi sГ„Вғ dorim rГ„Вғzboi, poate nu ar trebui sГ„Вғ cheltuim 800 de miliarde pe ГғВ®narmare ГҲВҷi poate ar trebui sГ„Вғ cГ„ВғutГ„Вғm soluГҲВӣii. Ce soluГҲВӣii sunt? DacГ„Вғ PreГҲВҷedinta Parlamentului European, doamna Roberta Metsola, a fost la Washington, am ГғВ®nГҲВӣeles cГ„Вғ a mers la cimitirul Arlington, dar n-a ajuns sГ„Вғ se ГғВ®ntГғВўlneascГ„Вғ cu Vance sau cu Trump. Atunci de ce s-a dus acolo, sГ„Вғ viziteze un cimitir? Poate dГғВўnsele ar trebui sГ„Вғ-ГҲВҷi dea demisia, sГ„Вғ punem alГҲВӣi lideri importanГҲВӣi ГғВ®n funcГҲВӣiile care conteazГ„Вғ ГҲВҷi sГ„Вғ stГ„Вғm la masГ„Вғ cu Trump pentru a gГ„Вғsi soluГҲВӣii de pace, cГ„Вғci altfel o sГ„Вғ ne ducem ГғВ®n... (cГғВўteva cuvinte care nu se aud)</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T19:47:39</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_287"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_400"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_401"/>
  </rdf:Description>
