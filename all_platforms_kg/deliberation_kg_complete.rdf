    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_129"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_176"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_177"/>
