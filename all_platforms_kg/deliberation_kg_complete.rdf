  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_517">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_517</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T22:23:33</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_254"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_516"/>
