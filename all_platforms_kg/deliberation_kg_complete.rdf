    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_264</del:identifier>
    <del:name>Beata SzydГ…ВӮo</del:name>
    <del:platform>EU Parliament</del:platform>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_ECR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_366">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_366</del:identifier>
    <del:text>Ci wszyscy, ktГғВіrzy myГ…ВӣlГ„В…, Г…Вјe moГ…Вјemy sobie poradziГ„ВҮ bez NATO i ci wszyscy, ktГғВіrzy prГғВіbujГ„В… w tej chwili obraГ…ВјaГ„ВҮ siГ„Вҷ na Stany Zjednoczone, popeГ…ВӮniajГ„В… ogromny bГ…ВӮГ„В…d. Trzeba wyciГ„В…gaГ„ВҮ wnioski, trzeba iГ…ВӣГ„ВҮ do przodu. Polski prezydent Andrzej Duda zaproponowaГ…ВӮ polskiemu rzГ„В…dowi, aГ…Вјeby zmieniГ„ВҮ konstytucjГ„Вҷ i wpisaГ„ВҮ 4% PKB z polskiego budГ…Вјetu jako gwarantowane Г…Вӣrodki na obronГ„Вҷ, mimo Г…Вјe Polska juГ…Вј wydaje 5% PKB. Mam nadziejГ„Вҷ, Г…Вјe polski rzГ„В…d przyjmie tГ„Вҷ propozycjГ„Вҷ, Г…Вјe wiГ„ВҷkszoГ…ВӣГ„ВҮ rzГ„В…dowa przyjmie tГ„Вҷ propozycjГ„Вҷ, i mam nadziejГ„Вҷ, Г…Вјe inne paГ…В„stwa czГ…ВӮonkowskie NATO zrozumiejГ„В…, Г…Вјe trzeba wywiГ„В…zywaГ„ВҮ siГ„Вҷ ze swoich zobowiГ„В…zaГ…В„, Г…Вјeby Europa byГ…ВӮa bezpieczna.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T19:01:44</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_264"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_365"/>
    <del:follows rdf:resource="https://w3id.org/deliberation/resource/contribution_366"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/creitem24">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Topic"/>
    <del:identifier>creitem24</del:identifier>
    <del:name>Deteriorating situation in Gaza following the non-extension of the ceasefire (debate)</del:name>
