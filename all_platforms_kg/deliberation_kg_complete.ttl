    del:text "Written Statements (Rule 178)" ;
    del:timestamp "2025-03-11T15:45:57"^^xsd:dateTime .

<https://w3id.org/deliberation/resource/contribution_239> a del:Contribution ;
    del:follows <https://w3id.org/deliberation/resource/contribution_237>,
        <https://w3id.org/deliberation/resource/contribution_239> ;
    del:identifier "contribution_239" ;
