<https://w3id.org/deliberation/resource/contribution_350> a del:Contribution ;
    del:follows <https://w3id.org/deliberation/resource/contribution_349>,
        <https://w3id.org/deliberation/resource/contribution_350> ;
    del:identifier "contribution_350" ;
