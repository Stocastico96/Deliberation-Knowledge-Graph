<https://w3id.org/deliberation/resource/contribution_283> a del:Contribution ;
    del:follows <https://w3id.org/deliberation/resource/contribution_282>,
        <https://w3id.org/deliberation/resource/contribution_283> ;
    del:identifier "contribution_283" ;
    del:madeBy <https://w3id.org/deliberation/resource/participant_81> ;
    del:text """And don't you think that we can have better solutions to the problems that do indeed rise with illegal immigration than putting people in camps, locking them away, taking their phones, taking their liberty and taking their rights?
(In response to laughter from another Member) ... And you laughing at that is a shame indeed!""" ;
    del:timestamp "2025-03-11T17:01:41"^^xsd:dateTime .

