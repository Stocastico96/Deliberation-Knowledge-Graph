  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_5">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_5</del:identifier>
    <del:name>Alice Kuhnke</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_Verts_ALE"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/ontology#Participant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Individuals or entities taking part in a deliberation process.</rdfs:comment>
