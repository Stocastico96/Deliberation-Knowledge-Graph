  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_5">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_5</del:identifier>
    <del:text>The corrigenda are available on the plenary webpage. Their titles will be published in the minutes of this sitting.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T17:06:09</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_1"/>
  </rdf:Description>
