  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_4">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_4</del:identifier>
    <del:text>These decisions will be set out in the minutes of today's sitting and take effect on the date of this announcement.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T17:05:53</del:timestamp>
