  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_307">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_307</del:identifier>
    <del:text>(Řečník souhlasil s tím, že že odpoví na otázku položenou zvednutím modré karty)</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-12T18:10:53</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_229"/>
