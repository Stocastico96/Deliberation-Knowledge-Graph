    <del:name>Christel Schaldemose</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_S&amp;D"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_275">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_275</del:identifier>
