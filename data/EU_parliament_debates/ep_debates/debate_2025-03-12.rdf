  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_85">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_85</del:identifier>
    <del:text>Tens of thousands of workers have already lost their jobs because our industry, especially the car industry, is not competitive against Asia and the United States. The utopia of the Green Deal was created thanks to von der Leyen and Timmermans' manipulation and corruption.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-12T11:18:04</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_71"/>
  </rdf:Description>
