  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_54">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_54</del:identifier>
    <del:name>Roberts Z脛芦le</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_ECR"/>
