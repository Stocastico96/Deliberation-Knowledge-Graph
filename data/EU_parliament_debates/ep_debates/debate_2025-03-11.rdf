    <del:identifier>participant_34</del:identifier>
    <del:name>脦聹脦卤脧聛脦炉脦卤 脦聳脦卤脧聡脦卤脧聛脦炉脦卤</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_NI"/>
