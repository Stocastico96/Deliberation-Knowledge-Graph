  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_334">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_334</del:identifier>
    <del:name>Jens Geier</del:name>
