  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_553">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_553</del:identifier>
    <del:text>Spo脜隆tovani, Izrael uporablja stradanje kot vojno sredstvo. To je vojni zlo脛聧in. Evropska unija in mednarodna skupnost morata ukrepati!
Ali bomo 脜隆e naprej gledali stran in dovoljevali nadaljevanje napadov na Gazo kot na Zahodnem bregu. In to medtem ko na eni strani Trump sanja o rivieri, Izrael na novo ri脜隆e zemljevide, Palestinci 脜隆e naprej brezupno umirajo.

Vse napore moramo usmeriti k dosegu dogovora druge faze, ki vklju脛聧uje trajno premirje kot tudi izpustitev vseh talcev. Evropska unija pa mora odlo脛聧no podpreti in aktivno pristopiti k arabskemu na脛聧rt za obnovo Gaze. Ra脛聧un za obnovo pa moramo izstaviti Izraelu, ki je odgovoren za skoraj popolno uni脛聧enje Gaze, ter tistim dr脜戮avam, ki so Izraelu ves 脛聧as vojne 脜隆e naprej dostavljale oro脜戮je. Hvala</del:text>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_383"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_112">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_112</del:identifier>
    <del:name>Sebastian Kruis</del:name>
