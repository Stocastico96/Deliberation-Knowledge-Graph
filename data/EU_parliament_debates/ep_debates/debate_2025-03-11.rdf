  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_360">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_360</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T18:56:11</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_259"/>
