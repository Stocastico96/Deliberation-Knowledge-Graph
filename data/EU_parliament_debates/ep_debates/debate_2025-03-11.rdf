  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_433">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_433</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T20:26:36</del:timestamp>
