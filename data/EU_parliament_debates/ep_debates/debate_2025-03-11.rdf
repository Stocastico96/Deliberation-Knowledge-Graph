  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_179">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_179</del:identifier>
    <del:name>Assita Kanko,</del:name>
