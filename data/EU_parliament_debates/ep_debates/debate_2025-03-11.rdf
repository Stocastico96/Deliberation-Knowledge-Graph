    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_63</del:identifier>
    <del:name>Marion Mar脙漏chal</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_ECR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/org_PPE">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Organization"/>
    <del:name>PPE</del:name>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_15">
