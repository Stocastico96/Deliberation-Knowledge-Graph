  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_107">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_107</del:identifier>
    <del:name>Carolina Morace</del:name>
