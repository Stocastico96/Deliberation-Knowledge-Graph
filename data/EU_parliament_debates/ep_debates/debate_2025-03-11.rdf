  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_240">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_240</del:identifier>
    <del:name>Vilis Kri脜隆topans</del:name>
