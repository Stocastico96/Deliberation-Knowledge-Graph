  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_144">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_144</del:identifier>
    <del:name>Oliv脙漏r V脙隆rhelyi,</del:name>
