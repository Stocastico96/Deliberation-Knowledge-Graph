  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_301">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_301</del:identifier>
    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T17:24:04</del:timestamp>
