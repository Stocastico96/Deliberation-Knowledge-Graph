  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_281">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_281</del:identifier>
    <del:name>脦聲脦录脦录脦卤脦陆脦驴脧聟脦庐脦禄 脦職脦碌脧聠脦卤脦禄脦驴脦鲁脦鹿脦卢脦陆脦陆脦路脧聜</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_PPE"/>
