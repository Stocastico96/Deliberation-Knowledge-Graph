  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_280">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_280</del:identifier>
    <del:name>脦聸脦驴脧聟脦潞脦卢脧聜 脦娄脦驴脧聟脧聛脦禄脦卢脧聜</del:name>
