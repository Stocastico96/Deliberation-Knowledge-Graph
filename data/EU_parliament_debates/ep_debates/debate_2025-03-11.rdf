  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/contribution_124">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Contribution"/>
    <del:identifier>contribution_124</del:identifier>
    <del:text>The minutes are approved.</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T13:08:32</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_1"/>
