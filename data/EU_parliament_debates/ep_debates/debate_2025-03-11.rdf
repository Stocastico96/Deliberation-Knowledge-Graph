  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_137">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_137</del:identifier>
    <del:name>Alessandra Moretti</del:name>
