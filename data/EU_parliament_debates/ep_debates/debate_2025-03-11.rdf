  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_154">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_154</del:identifier>
    <del:name>Tomislav Sokol</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_PPE"/>
