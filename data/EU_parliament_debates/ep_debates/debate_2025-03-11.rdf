    <del:text></del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T22:35:36</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_183">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_183</del:identifier>
    <del:name>Mary Khan,</del:name>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_31">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
    <del:identifier>participant_31</del:identifier>
    <del:name>Diana Riba i Giner</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_Verts_ALE"/>
