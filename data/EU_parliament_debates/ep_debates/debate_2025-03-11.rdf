    <del:identifier>participant_80</del:identifier>
    <del:name>脙聳zlem Demirel</del:name>
    <del:isAffiliatedWith rdf:resource="https://w3id.org/deliberation/resource/org_The Left"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/deliberation/resource/participant_272">
    <rdf:type rdf:resource="https://w3id.org/deliberation/ontology#Participant"/>
