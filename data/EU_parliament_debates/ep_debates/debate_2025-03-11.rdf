    <del:text>(Talaren godtog en fr脙楼ga ("bl脙楼tt kort").)</del:text>
    <del:timestamp rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-11T14:01:48</del:timestamp>
    <del:madeBy rdf:resource="https://w3id.org/deliberation/resource/participant_116"/>
