    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_66fe563a-f926-4104-9084-793d25a8dc52",
      "del:text": "'I''m going with <CARD>'",
      "del:madeBy": {
        "@id": "participant_3"
      },
