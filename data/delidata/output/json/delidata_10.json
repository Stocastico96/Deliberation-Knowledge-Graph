    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_ce3585dc-673c-43a6-a1ff-32ef42d69816",
      "del:text": "'My thinking was that if even numbers are behind the vowels it could be that the oppisite is also true . There is no way to tell of course but it''s is worth thinking about'",
      "del:madeBy": {
        "@id": "participant_2"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_1f798e00-5575-45b5-ae30-a98964b2a609"
