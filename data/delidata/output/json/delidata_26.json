      "del:identifier": "delidata_message_3f8af9e6-a01b-4274-b24f-77082ad5125a",
      "del:text": "'But you we don''t know what is on the other side of the <CARD>'",
      "del:madeBy": {
        "@id": "participant_3"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_4f93f7a5-f387-43ec-9adb-55b8cbd6c22f"
