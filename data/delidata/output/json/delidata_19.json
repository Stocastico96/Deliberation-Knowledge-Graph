  "del:hasArgument": [
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_d82118fd-b18b-4870-ae80-ad6cdf9f157f",
      "del:text": "I picked <CARD> and <CARD>"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_1b6ab035-7ddc-4a4d-b3c3-bab2bb03aafd",
      "del:text": "I just picked <CARD>"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_267e75d3-ba7e-45dc-83f0-698e431ff881",
      "del:text": "I picked <CARD> and <CARD> ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_b00bdab8-c591-4924-b46b-bfabbdcedeb6",
      "del:text": "Same here . I always overthink things though . Does the rule apply only to these 4 cards or to a larger set ( one for each letter of the English alphabet for example ? )"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_64421d7c-0295-488b-b24b-32895056a7f3",
      "del:text": "I figured even <CARD> would show if there was a vowel and letter ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_f62812c2-c3eb-4f23-b4e5-8cecc08c7dd6",
      "del:text": "<CARD> is odd , do you need to pick it ?"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_5dceebf9-b191-4ea0-81a6-67cc36d691e8",
      "del:text": "Yes ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_e7fde062-4b02-4ec2-89b8-8b019adc6944",
      "del:text": "<MENTION> . Why pick <CARD> ?"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_b250a73f-f4b1-4297-b920-a46c12dc6e69",
      "del:text": "If there is a vowel on the other side of <CARD> , the rule will be broken ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_af533f68-aec4-40c8-9ed7-d12996c0f41c",
      "del:text": "'<CARD> having a vowel doesn''t mean that every even number has a vowel'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_3c1d5d8c-550b-4dad-ab19-4692d6af292f",
      "del:text": "'It doesn''t say odd numbers can''t have a vowel'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_bdcc680a-01bc-46dc-a70d-47d84d398189",
      "del:text": "'Ok , I see <MENTION> ! A consonant could also have a vowel but that wouldn''t break the rule'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_e2af25ca-1346-4e10-ab88-9aa8ae4f704b",
      "del:text": "So do multiple people agree with <CARD> only ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_e1884384-688e-4224-b46d-d184c5284e41",
      "del:text": "I think you still need <CARD> thought , because it could have an odd number and that would also break the rule"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_12a9f404-a322-4122-9b04-dfef022fafee",
      "del:text": "It just says even numbers need to have vowels"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_2c21bfd8-9b79-475a-87e8-43a20eb9df51",
      "del:text": "Yes <CARD> is needed"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_eee44a77-a877-4791-8a7c-4293b4731373",
      "del:text": "<CARD> is needed because it may have a consonant"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_0ee22354-8786-45f4-858a-9f11c38fb883",
      "del:text": "'If <CARD> has a consonant it won''t break the rule .'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_eb9b3421-6082-4537-8438-cd81bd7e8ee2",
      "del:text": "'I don''t agree with <CARD> at all'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_8754ce9a-d507-437f-818d-0c1a7cdc2f0a",
      "del:text": "'If <CARD> - - an even number - doesn''t have a vowel , it breaks the rule'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_9d19c169-2040-426b-ae3f-814d72ea2988",
      "del:text": "The rule is just that vowels need to have even numbers ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_26e5bb1e-64e3-4a22-b2bf-254bb2524e5d",
      "del:text": "'No , because the rule is vowels have an even number . It doesn''t say consonants CAN''T also have even numbers .'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_247505b7-2dbd-4e59-8630-84419170ebab",
      "del:text": "'Wait , it doesn''t say even numbers can''t have a consonant It''s just <CARD>'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_b3631270-5229-4f9b-8c7f-ec5ac36e677c",
      "del:text": "We still need <CARD> though , because <CARD> having a vowel would break the rule ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_f87c53f1-da8b-4aa5-9479-fd64d4476b38",
      "del:text": "Does everyone agree on <CARD> and <CARD> ?"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_efe3e507-dc7a-4f5f-bfc2-dc29f3c8939b",
      "del:text": "<CARD> and <CARD>"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_6976b28c-c30b-45fe-8fd4-ba4d771ad356",
      "del:text": "Yes"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_4c764543-2ead-4eb9-b9a5-b3e7c52c784a",
      "del:text": "Ok ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_6111de96-24ad-490e-b5e7-9b0fb0ee09ff",
      "del:text": "<MENTION> ?"
    }
  ]
