      "del:identifier": "delidata_message_8290de00-8e98-4c9d-8e94-0ce2b46ffdb8",
      "del:text": "Would it be <CARD> and <CARD> ?",
      "del:madeBy": {
        "@id": "participant_2"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_5b63c8dc-81e8-46e8-98bd-59d68cde4088"
      },
      "del:hasArgument": {
        "@id": "delidata_argument_8290de00-8e98-4c9d-8e94-0ce2b46ffdb8"
      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_ed08b664-5108-4348-8d28-30e354fb2b77",
      "del:text": "'<CARD> could have a consonant on the other side and it wouldn''t impact anything .'",
      "del:madeBy": {
        "@id": "participant_3"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_5b63c8dc-81e8-46e8-98bd-59d68cde4088"
      },
      "del:hasArgument": {
        "@id": "delidata_argument_ed08b664-5108-4348-8d28-30e354fb2b77"
      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_2eeacac2-e5ed-49b8-8096-d362fa09aded",
      "del:text": "If we test the card with the vowel then we should test the card with the even number to make sure it has a vowel on it",
      "del:madeBy": {
        "@id": "participant_2"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_5b63c8dc-81e8-46e8-98bd-59d68cde4088"
      },
      "del:hasArgument": {
        "@id": "delidata_argument_2eeacac2-e5ed-49b8-8096-d362fa09aded"
      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_303e4ef4-76db-40e4-9c8c-c58c3152e1f5",
      "del:text": "'it doesn''t state that all even numbers have a vowel . it just says all cards with vowels have an even number'",
      "del:madeBy": {
        "@id": "participant_3"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_5b63c8dc-81e8-46e8-98bd-59d68cde4088"
