      "del:identifier": "delidata_message_5bafd16e-fe6b-452b-a3b4-04311a47e903",
      "del:text": "must be <CARD> right ?",
      "del:madeBy": {
        "@id": "participant_3"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_5b63c8dc-81e8-46e8-98bd-59d68cde4088"
      },
      "del:hasArgument": {
        "@id": "delidata_argument_5bafd16e-fe6b-452b-a3b4-04311a47e903"
      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_e1d012e4-33a5-4f82-a6e1-6f0e4e8854a1",
      "del:text": "we only need to check the cards with vowels . none are there except <CARD> , so it has to be <CARD>",
      "del:madeBy": {
        "@id": "participant_3"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_5b63c8dc-81e8-46e8-98bd-59d68cde4088"
