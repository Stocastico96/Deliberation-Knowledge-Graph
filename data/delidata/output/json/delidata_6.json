      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_cc0b4e23-feb1-4c7e-91f8-8f9aac7b2062",
      "del:text": "'We don''t need to turn the five because it is odd and that would not tell us anything about a vowel card .'",
      "del:madeBy": {
        "@id": "participant_2"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_cc4fa8e4-2d8b-44d2-b3a5-fe569a488397"
      },
      "del:hasArgument": {
        "@id": "delidata_argument_cc0b4e23-feb1-4c7e-91f8-8f9aac7b2062"
      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_6d24924c-727b-48ba-bb12-efdf1b6a1c17",
      "del:text": "'We can''t be certain the rule is always true either way , but only the first two cards matter in this case .'",
      "del:madeBy": {
        "@id": "participant_3"
      },
      "del:hasTopic": {
        "@id": "delidata_topic_cc4fa8e4-2d8b-44d2-b3a5-fe569a488397"
      },
      "del:hasArgument": {
