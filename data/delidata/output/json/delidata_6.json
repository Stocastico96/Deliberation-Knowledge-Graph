      }
    },
    {
      "@type": "del:Contribution",
      "del:identifier": "delidata_message_b550b776-7dcf-4326-bbbd-d9a08604cf6d",
      "del:text": "The only card that matters is <CARD> .",
      "del:madeBy": {
        "@id": "participant_2"
