      "@type": "del:Argument",
      "del:identifier": "delidata_argument_6f6c5455-1132-464d-8ab3-a3ceef2f07c3",
      "del:text": "'it doesn''t matter . it doesn''t say all evven numbers have a vowel on the other side .'"
