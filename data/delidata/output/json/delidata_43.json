    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_cdc61fc2-04d5-44d8-a1ce-c868dc6193f5",
      "del:text": "<CARD> is incorrect . it does not state that it is reciprocal"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_9df52583-6305-4827-b1dc-84f7f2e7c4c1",
      "del:text": "I think <MENTION> is correct"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_9a5afa68-9ab5-4b89-bb91-4c58d71fe5c8",
      "del:text": "have vowel / have even . not have even / have vowel"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_47725a56-16b1-4e5e-aee4-7fcf11696b8d",
      "del:text": "It does feel like <CARD> would be the choice"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_7151ae58-b1ca-4c1e-9030-2688b235c5c7",
      "del:text": "'Because it''s only stating \" all cards with vowels \"'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_82a204d3-4175-4cf3-89f0-4bd786a57af6",
      "del:text": "yes , <CARD> ."
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_8a09d368-e780-435a-8877-2e822d15b1c1",
      "del:text": "'But wouldn''t you want to see if there was a vowel on the other side of <CARD> ?'"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_f5dfd3cc-3e65-4a16-a77a-bfea274c7ff3",
      "del:text": "All cards with vowels on one side have an even number on the other ."
