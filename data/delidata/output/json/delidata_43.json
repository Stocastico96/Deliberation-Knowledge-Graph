      "del:text": "<CARD> is the answer correct ?"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_3d2489f2-ab34-490d-98ee-e952a86b6575",
      "del:text": "no . it would be <CARD>"
    },
    {
      "@type": "del:Argument",
      "del:identifier": "delidata_argument_a41060f1-8e5b-4cc1-a0ea-25f22028995f",
      "del:text": "I think <CARD> and <CARD> actually"
