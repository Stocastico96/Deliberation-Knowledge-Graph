    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "I believe the EU should push for a twoâstate solution and challenge its biggest ally. Now, more than ever, we should act independently from the United States in order to stop the genocide of Palestinians and finally achieve a twoâstate solution."
      }
