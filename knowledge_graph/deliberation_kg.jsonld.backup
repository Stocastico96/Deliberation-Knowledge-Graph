      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-11T10:13:44"
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-12T09:47:01"
      }
    ]
