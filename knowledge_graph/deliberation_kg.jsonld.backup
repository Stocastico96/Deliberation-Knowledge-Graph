    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "Ich hÃ¤tte mir gewÃ¼nscht, dass die, die an der Debatte teilgenommen haben, vielleicht auch noch bis zum Ende da geblieben wÃ¤ren.\nIch bedanke mich ausdrÃ¼cklich bei der Kommission und beim Rat fÃ¼r die Anwesenheit bis zum Schluss.\nSchriftliche ErklÃ¤rungen (Artikel 178)"
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
