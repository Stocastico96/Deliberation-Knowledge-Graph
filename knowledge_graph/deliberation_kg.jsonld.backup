      {
        "@id": "https://w3id.org/deliberation/resource/participant_229"
      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": ""
      },
      {
        "@value": "(Řečník souhlasil s tím, že že odpoví na otázku položenou zvednutím modré karty)"
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
