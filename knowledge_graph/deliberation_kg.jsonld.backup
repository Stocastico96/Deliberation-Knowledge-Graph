      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": "Written Statements (Rule 178)"
      },
      {
        "@value": "You always talk about the interests of children – and I agree with you, we are all here trying to protect the interests of children.\nNow, would you be able to explain to me how the interests of a child who has always known two mothers, of whom one of the mothers now may be terminally ill and might die, will be taken care of, the interests of that child, if the other mother – who is not his biological mother – is not recognised as a mother? Because that is what is happening in Italy at the moment."
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-11T17:27:24"
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-12T18:06:46"
      }
    ]
  },
  {
    "@id": "https://w3id.org/deliberation/resource/contribution_495",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
    ],
    "https://w3id.org/deliberation/ontology#identifier": [
      {
        "@value": "contribution_495"
