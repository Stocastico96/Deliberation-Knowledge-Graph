  {
    "@id": "https://w3id.org/deliberation/resource/contribution_28",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
    ],
    "https://w3id.org/deliberation/ontology#identifier": [
      {
        "@value": "contribution_28"
      }
    ],
    "https://w3id.org/deliberation/ontology#madeBy": [
      {
        "@id": "https://w3id.org/deliberation/resource/participant_3"
      },
      {
        "@id": "https://w3id.org/deliberation/resource/participant_24"
