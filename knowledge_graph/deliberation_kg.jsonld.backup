      {
        "@id": "https://w3id.org/deliberation/resource/participant_212"
      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": ""
      },
      {
        "@value": "Hinter jedem Unternehmen stehen Millionen von Arbeitnehmerinnen und Arbeitnehmern, die am Ende des Tages ihr Lohn und Brot dafür benötigen, um auch in der heutigen Zeit die Lebenshaltungskosten überhaupt noch bestreiten zu können, eine Familie zu gründen und letztendlich damit auch die Zukunft Europas in die nächste Generation zu tragen.\nDas heißt, starke Arbeitnehmerrechte im Einklang mit starken Unternehmen sind die Zukunft und bilden die Zukunft Europas. Eine starke europäische Wirtschaft und der soziale Schutz sind entsprechend keine Gegensätze."
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-11T17:02:26"
