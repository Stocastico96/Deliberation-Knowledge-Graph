    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": ""
      },
      {
        "@value": "I give the floor to the rapporteur for two minutes."
      },
      {
        "@value": "I would like to inform you that the name of Péter Magyar appeared in error on the joint motion for a resolution on the future of European defence. This editorial misprint will be corrected."
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
