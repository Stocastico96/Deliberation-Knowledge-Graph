    "https://w3id.org/deliberation/ontology#name": [
      {
        "@value": "Wouter Beke"
      },
      {
        "@value": "Sigrid Friis,"
      }
    ]
  },
  {
    "@id": "https://w3id.org/deliberation/resource/contribution_194",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
    ],
    "https://w3id.org/deliberation/ontology#identifier": [
      {
        "@value": "contribution_194"
      }
    ],
    "https://w3id.org/deliberation/ontology#madeBy": [
      {
        "@id": "https://w3id.org/deliberation/resource/participant_117"
      },
      {
        "@id": "https://w3id.org/deliberation/resource/participant_141"
      },
      {
        "@id": "https://w3id.org/deliberation/resource/participant_155"
      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": ""
      },
      {
        "@value": "But itâs important to remember that this celebration is not just for one day â it is a commitment to equality every day. True equality goes beyond recognition; itâs about ensuring equal opportunity for all. Itâs about creating a world where no girl grows up believing she has to fight harder to be heard. We should dismantle barriers, challenge outdated mindsets and build an environment where talent, not gender, defines success.\nFrom the boardroom to the classroom, from theÂ front lines to the voting booths, women are constantly redefining leadership. Yet too many still face discrimination, unequal opportunities and violence. These injustices must have no place in our societies.\nOur words today should turn into actions tomorrow. The future we strive for â a world where every woman and girl can dream without limits â is not just an aspiration; it is a necessity. And as the European Parliament, we must work hard to make this future a reality for all."
      },
      {
        "@value": "Déclarations écrites (article 178)"
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-10T21:58:24"
      },
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-12T15:18:52"
      }
    ]
