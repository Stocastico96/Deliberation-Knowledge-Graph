      {
        "@value": "Barry Andrews,"
      }
    ]
  },
  {
    "@id": "https://w3id.org/deliberation/resource/contribution_499",
    "@type": [
      "https://w3id.org/deliberation/ontology#Contribution"
    ],
    "https://w3id.org/deliberation/ontology#identifier": [
      {
        "@value": "contribution_499"
