      {
        "@id": "https://w3id.org/deliberation/resource/participant_58"
      }
    ],
    "https://w3id.org/deliberation/ontology#text": [
      {
        "@value": ""
      },
      {
        "@value": "But, as you are from the Socialist Party from Spain, just a very small, tiny question: what is your opinion on why Spain has provided so little help to Ukraine currently? Because when you look at the GDP, the real help â military aid â it has given to Ukraine, it's almost nothing compared to Poland, Estonia, Denmark, Finland and so on. So, why is there so much talk and no actions? What is the problem in Spain with the Socialists? Why are you not acting?"
      },
      {
        "@value": "(Mówca zgodził się na pytanie zasygnalizowane przez podniesienie niebieskiej kartki)"
      }
    ],
    "https://w3id.org/deliberation/ontology#timestamp": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#dateTime",
        "@value": "2025-03-10T18:53:46"
      },
