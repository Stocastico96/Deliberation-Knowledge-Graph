      }
    ],
    "https://w3id.org/deliberation/ontology#name": [
      {
        "@value": "ÎÎ¹ÏÎ¬Î»Î·Ï Î§Î±ÏÎ¶Î·ÏÎ±Î½ÏÎ­Î»Î±"
